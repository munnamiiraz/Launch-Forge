{
  "info": {
    "name": "Pricemoney Module API",
    "description": "Postman collection for testing Pricemoney Module endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api/v1",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "waitlistId",
      "value": "cmn1234567890abcdef",
      "type": "string"
    },
    {
      "key": "workspaceId",
      "value": "ws1234567890abcdef",
      "type": "string"
    },
    {
      "key": "prizeId",
      "value": "prize1234567890ab",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Create Prize",
      "request": {
        "method": "POST",
        "url": {
          "raw": "{{baseUrl}}/prizes",
          "host": ["{{baseUrl}}"],
          "path": ["prizes"]
        },
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Cookie",
            "value": "auth_token={{authToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"waitlistId\": \"{{waitlistId}}\",\n  \"workspaceId\": \"{{workspaceId}}\",\n  \"title\": \"iPhone 15 Pro\",\n  \"description\": \"Win the latest iPhone\",\n  \"prizeType\": \"CASH\",\n  \"value\": 999,\n  \"currency\": \"USD\",\n  \"rankFrom\": 1,\n  \"rankTo\": 1,\n  \"imageUrl\": \"https://example.com/iphone.jpg\",\n  \"expiresAt\": \"2026-12-31T23:59:59Z\"\n}"
        }
      }
    },
    {
      "name": "Update Prize",
      "request": {
        "method": "PATCH",
        "url": {
          "raw": "{{baseUrl}}/prizes/{{prizeId}}",
          "host": ["{{baseUrl}}"],
          "path": ["prizes", "{{prizeId}}"]
        },
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Cookie",
            "value": "auth_token={{authToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"workspaceId\": \"{{workspaceId}}\",\n  \"waitlistId\": \"{{waitlistId}}\",\n  \"title\": \"Updated Prize Title\",\n  \"value\": 1500,\n  \"status\": \"ACTIVE\"\n}"
        }
      }
    },
    {
      "name": "Delete Prize",
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "{{baseUrl}}/prizes/{{prizeId}}",
          "host": ["{{baseUrl}}"],
          "path": ["prizes", "{{prizeId}}"]
        },
        "header": [
          {
            "key": "Cookie",
            "value": "auth_token={{authToken}}"
          }
        ]
      }
    },
    {
      "name": "Get Prizes by Waitlist (Authenticated)",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/prizes/waitlist/{{waitlistId}}",
          "host": ["{{baseUrl}}"],
          "path": ["prizes", "waitlist", "{{waitlistId}}"]
        },
        "header": [
          {
            "key": "Cookie",
            "value": "auth_token={{authToken}}"
          }
        ]
      }
    },
    {
      "name": "Get Public Prizes (No Auth)",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/prizes/public/{{waitlistId}}",
          "host": ["{{baseUrl}}"],
          "path": ["prizes", "public", "{{waitlistId}}"]
        },
        "header": []
      }
    }
  ]
}
