generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/client"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}


model User {
  id                   String            @id
  name                 String
  email                String            @unique
  emailVerified        Boolean           @default(false)
  image                String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  role                 String            @default("USER")
  status               String            @default("ACTIVE")
  needPasswordChange   Boolean           @default(false)
  isDeleted            Boolean           @default(false)
  deletedAt            DateTime?
  newsLadder           Boolean           @default(false)
  newsLadderId         String?           @unique
  bio                  String?
  timezone             String?           @default("UTC")
  website              String?
  accounts             Account[]
  payments             Payment?
  sessions             Session[]
  ownedWorkspaces      Workspace[]       @relation("WorkspaceOwner")
  workspaceMemberships WorkspaceMember[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Workspace {
  id             String            @id @default(cuid())
  name           String
  slug           String            @unique
  logo           String?
  ownerId        String
  plan           Plan              @default(FREE)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  deletedAt      DateTime?
  changelogs     Changelog[]
  feedbackBoards FeedbackBoard[]
  roadmaps       Roadmap[]
  waitlists      Waitlist[]
  owner          User              @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  members        WorkspaceMember[]

  @@index([ownerId])
  @@index([slug])
  @@index([deletedAt])
  @@map("workspace")
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(MEMBER)
  joinedAt    DateTime      @default(now())
  deletedAt   DateTime?
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId])
  @@index([deletedAt])
  @@map("workspace_member")
}

model Waitlist {
  id          String             @id @default(cuid())
  workspaceId String
  name        String
  slug        String
  description String?
  logoUrl     String?
  theme       String?
  isOpen      Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  deletedAt   DateTime?
  endDate     DateTime?
  archivedAt  DateTime?
  category    String?            @default("OTHER")
  prizes      LeaderboardPrize[]
  subscribers Subscriber[]
  workspace   Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, slug])
  @@index([workspaceId])
  @@index([deletedAt])
  @@index([archivedAt])
  @@map("waitlist")
}

model Subscriber {
  id             String       @id @default(cuid())
  waitlistId     String
  name           String
  email          String
  referralCode   String       @unique
  referredById   String?
  referralsCount Int          @default(0)
  isConfirmed    Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  referredBy     Subscriber?  @relation("Referrals", fields: [referredById], references: [id])
  referrals      Subscriber[] @relation("Referrals")
  waitlist       Waitlist     @relation(fields: [waitlistId], references: [id], onDelete: Cascade)

  @@unique([waitlistId, email])
  @@index([waitlistId])
  @@index([referralCode])
  @@index([referredById])
  @@index([waitlistId, referralsCount])
  @@index([deletedAt])
  @@map("subscriber")
}

model FeedbackBoard {
  id              String           @id @default(cuid())
  workspaceId     String
  name            String
  slug            String
  description     String?
  isPublic        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  featureRequests FeatureRequest[]
  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, slug])
  @@index([workspaceId])
  @@index([deletedAt])
  @@map("feedback_board")
}

model FeatureRequest {
  id          String               @id @default(cuid())
  boardId     String
  title       String
  description String?
  status      FeatureRequestStatus @default(UNDER_REVIEW)
  votesCount  Int                  @default(0)
  authorEmail String?
  authorName  String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  deletedAt   DateTime?
  comments    Comment[]
  board       FeedbackBoard        @relation(fields: [boardId], references: [id], onDelete: Cascade)
  votes       Vote[]

  @@index([boardId])
  @@index([boardId, status])
  @@index([boardId, votesCount])
  @@index([deletedAt])
  @@map("feature_request")
}

model Vote {
  id               String         @id @default(cuid())
  featureRequestId String
  voterEmail       String
  createdAt        DateTime       @default(now())
  featureRequest   FeatureRequest @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)

  @@unique([featureRequestId, voterEmail])
  @@index([featureRequestId])
  @@map("vote")
}

model Comment {
  id               String         @id @default(cuid())
  featureRequestId String
  authorEmail      String
  authorName       String?
  body             String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?
  featureRequest   FeatureRequest @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)

  @@index([featureRequestId])
  @@index([deletedAt])
  @@map("comment")
}

model Roadmap {
  id          String        @id @default(cuid())
  workspaceId String
  name        String
  slug        String
  description String?
  isPublic    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  items       RoadmapItem[]

  @@unique([workspaceId, slug])
  @@index([workspaceId])
  @@index([deletedAt])
  @@map("roadmap")
}

model RoadmapItem {
  id          String        @id @default(cuid())
  roadmapId   String
  title       String
  description String?
  status      RoadmapStatus @default(PLANNED)
  sortOrder   Int           @default(0)
  eta         DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?
  roadmap     Roadmap       @relation(fields: [roadmapId], references: [id], onDelete: Cascade)

  @@index([roadmapId])
  @@index([roadmapId, status])
  @@index([deletedAt])
  @@map("roadmap_item")
}

model Changelog {
  id          String    @id @default(cuid())
  workspaceId String
  version     String?
  title       String
  body        String
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, publishedAt])
  @@index([deletedAt])
  @@map("changelog")
}

model Payment {
  id                 String        @id @default(uuid(7))
  amount             Float
  transactionId      String        @unique
  stripeEventId      String?       @unique
  status             PaymentStatus @default(UNPAID)
  paymentGatewayData Json?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  planMode           PaymentMode   @default(MONTHLY)
  planType           PaymentType   @default(PRO)
  userId             String        @unique
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([transactionId])
  @@map("payments")
}

model LeaderboardPrize {
  id          String      @id @default(cuid())
  waitlistId  String
  title       String
  description String?
  prizeType   PrizeType   @default(CUSTOM)
  value       Float?
  currency    String?
  rankFrom    Int
  rankTo      Int
  imageUrl    String?
  status      PrizeStatus @default(ACTIVE)
  expiresAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?
  waitlist    Waitlist    @relation(fields: [waitlistId], references: [id], onDelete: Cascade)

  @@index([waitlistId])
  @@index([waitlistId, status])
  @@index([deletedAt])
  @@map("leaderboard_prize")
}

model Knowledge {
  id        String   @id @default(cuid())
  content   String
  metadata  Json?
  embedding Unsupported("vector(1536)")?
  createdAt DateTime @default(now())

  @@map("knowledge")
}

enum Plan {
  FREE
  STARTER
  PRO
  GROWTH
}

enum WorkspaceRole {
  OWNER
  MEMBER
}

enum FeatureRequestStatus {
  UNDER_REVIEW
  PLANNED
  IN_PROGRESS
  COMPLETED
  DECLINED
}

enum RoadmapStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
}

enum PrizeType {
  CASH
  GIFT_CARD
  PRODUCT
  LIFETIME_ACCESS
  DISCOUNT
  CUSTOM
}

enum PrizeStatus {
  ACTIVE
  AWARDED
  CANCELLED
}

enum PaymentStatus {
  PAID
  UNPAID
}

enum PaymentMode {
  MONTHLY
  YEARLY
}

enum PaymentType {
  PRO
  GROWTH
}
