generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String    @id
  name               String
  email              String    @unique
  emailVerified      Boolean   @default(false)
  image              String?
  bio                String?
  website            String?
  timezone           String?   @default("UTC")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  role               String    @default("USER")
  status             String    @default("ACTIVE")
  needPasswordChange Boolean   @default(false)
  isDeleted          Boolean   @default(false)
  deletedAt          DateTime?
  sessions           Session[]
  accounts           Account[]
  newsLadder         Boolean   @default(false)
  newsLadderId       String?   @unique

  workspaceMemberships WorkspaceMember[]
  ownedWorkspaces      Workspace[]       @relation("WorkspaceOwner")
  payments             Payment[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Workspace {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique // used in subdomain: slug.launchforge.com
  logo      String?
  ownerId   String
  plan      Plan      @default(FREE)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  owner          User              @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  members        WorkspaceMember[]
  waitlists      Waitlist[]
  feedbackBoards FeedbackBoard[]
  roadmaps       Roadmap[]
  changelogs     Changelog[]

  @@index([ownerId])
  @@index([slug])
  @@index([deletedAt])
  @@map("workspace")
}

enum Plan {
  FREE
  STARTER
  PRO
  GROWTH
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(MEMBER)
  joinedAt    DateTime      @default(now())
  deletedAt   DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId]) // one membership per user per workspace
  @@index([userId])
  @@index([workspaceId])
  @@index([deletedAt])
  @@map("workspace_member")
}

enum WorkspaceRole {
  OWNER
  MEMBER
}

model Waitlist {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  slug        String // product.launchforge.com/{slug}
  description String?
  logoUrl     String?
  theme       String? // JSON blob or enum later
  isOpen      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  endDate     DateTime?

  workspace   Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  subscribers Subscriber[]
  prizes      LeaderboardPrize[]

  @@unique([workspaceId, slug])
  @@index([workspaceId])
  @@index([deletedAt])
  @@map("waitlist")
}

model Subscriber {
  id             String    @id @default(cuid())
  waitlistId     String
  name           String
  email          String
  referralCode   String    @unique // launchforge.com/ref/{referralCode}
  referredById   String? // subscriber who referred this person
  referralsCount Int       @default(0) // denormalised counter — updated via trigger/job
  // Queue position is derived: ORDER BY referralsCount DESC, createdAt ASC
  isConfirmed    Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  waitlist   Waitlist     @relation(fields: [waitlistId], references: [id], onDelete: Cascade)
  referredBy Subscriber?  @relation("Referrals", fields: [referredById], references: [id])
  referrals  Subscriber[] @relation("Referrals")

  @@unique([waitlistId, email]) // no duplicate emails per waitlist
  @@index([waitlistId])
  @@index([referralCode])
  @@index([referredById])
  @@index([waitlistId, referralsCount]) // leaderboard queries
  @@index([deletedAt])
  @@map("subscriber")
}

model FeedbackBoard {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  slug        String
  description String?
  isPublic    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  featureRequests FeatureRequest[]

  @@unique([workspaceId, slug])
  @@index([workspaceId])
  @@index([deletedAt])
  @@map("feedback_board")
}

model FeatureRequest {
  id          String               @id @default(cuid())
  boardId     String
  title       String
  description String?
  status      FeatureRequestStatus @default(UNDER_REVIEW)
  votesCount  Int                  @default(0) // denormalised — updated on vote insert/delete
  authorEmail String? // nullable: public users may not be registered
  authorName  String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  deletedAt   DateTime?

  board    FeedbackBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  votes    Vote[]
  comments Comment[]

  @@index([boardId])
  @@index([boardId, status])
  @@index([boardId, votesCount]) // sort by popularity
  @@index([deletedAt])
  @@map("feature_request")
}

enum FeatureRequestStatus {
  UNDER_REVIEW
  PLANNED
  IN_PROGRESS
  COMPLETED
  DECLINED
}

model Vote {
  id               String   @id @default(cuid())
  featureRequestId String
  voterEmail       String // anonymous voters identified by email
  createdAt        DateTime @default(now())

  featureRequest FeatureRequest @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)

  @@unique([featureRequestId, voterEmail]) // one vote per email per request
  @@index([featureRequestId])
  @@map("vote")
}

model Comment {
  id               String    @id @default(cuid())
  featureRequestId String
  authorEmail      String
  authorName       String?
  body             String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  featureRequest FeatureRequest @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)

  @@index([featureRequestId])
  @@index([deletedAt])
  @@map("comment")
}

model Roadmap {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  slug        String
  description String?
  isPublic    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  workspace Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  items     RoadmapItem[]

  @@unique([workspaceId, slug])
  @@index([workspaceId])
  @@index([deletedAt])
  @@map("roadmap")
}

model RoadmapItem {
  id          String        @id @default(cuid())
  roadmapId   String
  title       String
  description String?
  status      RoadmapStatus @default(PLANNED)
  sortOrder   Int           @default(0) // manual drag-and-drop ordering
  eta         DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  roadmap Roadmap @relation(fields: [roadmapId], references: [id], onDelete: Cascade)

  @@index([roadmapId])
  @@index([roadmapId, status])
  @@index([deletedAt])
  @@map("roadmap_item")
}

enum RoadmapStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
}

model Changelog {
  id          String    @id @default(cuid())
  workspaceId String
  version     String? // e.g. "v1.2"
  title       String
  body        String // markdown
  publishedAt DateTime? // null = draft
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, publishedAt])
  @@index([deletedAt])
  @@map("changelog")
}

model Payment {
  id                 String        @id @default(uuid(7))
  amount             Float
  transactionId      String        @unique
  stripeEventId      String?       @unique
  status             PaymentStatus @default(UNPAID)
  paymentGatewayData Json?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  planMode           PaymentMode   @default(MONTHLY)
  planType           PaymentType   @default(PRO)

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([transactionId])
  @@map("payments")
}

model LeaderboardPrize {
  id         String @id @default(cuid())
  waitlistId String

  title       String
  description String?
  prizeType   PrizeType @default(CUSTOM)
  value       Float? // monetary value if applicable
  currency    String? // ISO 4217, e.g. "USD"

  rankFrom Int // inclusive lower bound — e.g. 1
  rankTo   Int // inclusive upper bound — e.g. 3

  imageUrl  String?
  status    PrizeStatus @default(ACTIVE)
  expiresAt DateTime? // null = never expires

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  waitlist Waitlist @relation(fields: [waitlistId], references: [id], onDelete: Cascade)

  // Unique: a waitlist can't have two active prizes for the same exact rank band.
  // Overlap detection is enforced at the application layer (hasRankOverlap util).
  @@index([waitlistId])
  @@index([waitlistId, status])
  @@index([deletedAt])
  @@map("leaderboard_prize")
}

enum PrizeType {
  CASH
  GIFT_CARD
  PRODUCT
  LIFETIME_ACCESS
  DISCOUNT
  CUSTOM
}

enum PrizeStatus {
  ACTIVE
  AWARDED
  CANCELLED
}

enum PaymentStatus {
  PAID
  UNPAID
}

enum PaymentMode {
  MONTHLY
  YEARLY
}

enum PaymentType {
  PRO
  GROWTH
}
